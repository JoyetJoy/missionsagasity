{
  "name": "mission-sagacity-api",
  "version": "1.0.0",
  "description": "Mission Sagacity community portal API backend",
  "main": "dist/server.js",
  "scripts": {
    "new_build": "npm run prod",
    "server": "tsx watch src/server.ts",
    "server:prod": "node dist/server.js",
    "dev": "NODE_ENV=development npm-run-all server",
    "clean": "rimraf dist",
    "prod": "NODE_ENV=production npm-run-all clean build server:prod",
    "watch": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "pg:pull": "prisma db pull --schema=prisma/schema.prisma",
    "pg:gen": "prisma generate --schema=prisma/schema.prisma",
    "studio:pg": "prisma studio --schema=prisma/schema.prisma",
    "pg:push": "prisma db push --schema=prisma/schema.prisma",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:init": "psql $DATABASE_URL -f schema-and-seed.sql"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@prisma/client": "^6.19.3",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^22.7.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prisma": "^6.19.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
